generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String?
  password     String
  smsCredits   Int       @default(0)
  isAdmin      Boolean   @default(false)
  lastLoginAt         DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  referralCode     String?   @unique
  referredByUserId Int?
  referredBy       User?     @relation("referrals", fields: [referredByUserId], references: [id])
  referredUsers    User[]    @relation("referrals")

  shops              Shop[]
  creditTransactions CreditTransaction[]
}

model CreditTransaction {
  id          Int      @id @default(autoincrement())
  userId      Int
  amount      Int
  type        CreditType
  description String
  price       Float    @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
}

enum CreditType {
  PURCHASE
  USAGE
}

model Shop {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String?
  shopDomain     String?  @unique
  accessToken    String?
  webhookSecret  String?
  smsTemplate    String?
  smsStartHour   Int      @default(9)
  smsEndHour     Int      @default(21)
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id])
  orders        Order[]
  blockedPhones BlockedPhone[]
}

model BlockedPhone {
  id        Int      @id @default(autoincrement())
  phone     String
  shopId    Int
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([phone, shopId])
}

model Order {
  id              Int         @id @default(autoincrement())
  shopifyOrderId  BigInt?
  customerName    String
  customerPhone   String
  total           Float
  status          OrderStatus @default(PENDING)
  shopId          Int
  confirmToken    String?     @unique
  tokenExpiresAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  shop            Shop        @relation(fields: [shopId], references: [id])
  smsLogs         SMSLog[]
}

model SMSLog {
  id           Int       @id @default(autoincrement())
  phone        String
  message      String
  status       SMSStatus @default(PENDING)
  errorMessage String?
  orderId      Int
  createdAt    DateTime  @default(now())

  order        Order     @relation(fields: [orderId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SMSStatus {
  PENDING
  SENT
  FAILED
}
