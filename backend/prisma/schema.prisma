generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  name                String?
  password            String
  emailVerified       Boolean   @default(false)
  emailVerifyToken    String?
  smsCredits          Int       @default(0)
  whatsappCredits     Int       @default(0)
  isAdmin             Boolean   @default(false)
  lastLoginAt         DateTime?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  plan                PlanType  @default(FREE)
  planExpiresAt       DateTime?
  billingCycle        String    @default("monthly")
  twoFactorSecret     String?
  twoFactorEnabled    Boolean   @default(false)
  referralCode        String?   @unique
  referredByUserId    Int?
  referredBy          User?     @relation("referrals", fields: [referredByUserId], references: [id])
  referredUsers       User[]    @relation("referrals")

  shops              Shop[]
  creditTransactions CreditTransaction[]
  refreshTokens      RefreshToken[]
  subscriptions      Subscription[]
}

model CreditTransaction {
  id          Int        @id @default(autoincrement())
  userId      Int
  amount      Int
  type        CreditType
  description String
  price       Float      @default(0)
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum PlanType {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum CreditType {
  PURCHASE
  USAGE
  WHATSAPP_PURCHASE
  ADMIN_GIFT
}

model Shop {
  id                      Int      @id @default(autoincrement())
  name                    String
  phone                   String?
  shopDomain              String?  @unique
  accessToken             String?
  webhookSecret           String?
  smsTemplate             String?
  notificationChannel     String   @default("sms")
  smsStartHour            Int      @default(9)
  smsEndHour              Int      @default(21)
  userId                  Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  prepaidEnabled          Boolean  @default(false)
  prepaidDiscount         Int      @default(5)
  advancedBlockingEnabled Boolean  @default(true)
  maxOrdersPerPhone30d    Int?     @default(3)
  maxOrdersPerIp30d       Int?     @default(5)

  user               User                @relation(fields: [userId], references: [id])
  orders             Order[]
  blockedPhones      BlockedPhone[]
  blockedPostalCodes BlockedPostalCode[]
  blockingRules      BlockingRule[]
  blockedOrders      BlockedOrder[]
}

model BlockedPhone {
  id        Int      @id @default(autoincrement())
  phone     String
  shopId    Int
  createdAt DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([phone, shopId])
}

model BlockedPostalCode {
  id         Int      @id @default(autoincrement())
  postalCode String
  shopId     Int
  createdAt  DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([postalCode, shopId])
}

model Order {
  id             Int         @id @default(autoincrement())
  shopifyOrderId BigInt?
  customerName   String
  customerPhone  String
  total          Float
  status         OrderStatus @default(PENDING)
  shopId         Int
  confirmToken   String?     @unique
  statusToken    String?     @unique
  tokenExpiresAt DateTime?
  otpCode        String?
  otpVerified    Boolean     @default(false)
  otpAttempts    Int         @default(0)
  ipAddress      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  shop    Shop     @relation(fields: [shopId], references: [id])
  smsLogs SMSLog[]

  @@index([shopId, customerPhone, createdAt])
  @@index([shopId, ipAddress, createdAt])
}

model SMSLog {
  id           Int       @id @default(autoincrement())
  phone        String
  message      String
  status       SMSStatus @default(PENDING)
  errorMessage String?
  orderId      Int
  createdAt    DateTime  @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
  BLOCKED
}

enum SMSStatus {
  PENDING
  SENT
  FAILED
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SecurityLog {
  id        Int      @id @default(autoincrement())
  ip        String
  endpoint  String
  reason    String
  createdAt DateTime @default(now())
}

model Subscription {
  id           Int       @id @default(autoincrement())
  userId       Int
  plan         PlanType
  billingCycle String
  startedAt    DateTime  @default(now())
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlockingRule {
  id          Int              @id @default(autoincrement())
  shopId      Int
  shop        Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  ruleType    BlockingRuleType
  value       String
  reason      String?
  isActive    Boolean          @default(true)
  matchCount  Int              @default(0)
  lastMatched DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([shopId, ruleType, isActive])
  @@index([shopId, value])
}

enum BlockingRuleType {
  IP_ADDRESS
  IP_RANGE
  PHONE_PATTERN
  EMAIL_DOMAIN
  CUSTOMER_NAME
  MAX_ORDERS_PER_PHONE
  MAX_ORDERS_PER_IP
}

model BlockedOrder {
  id             Int         @id @default(autoincrement())
  shopId         Int
  shop           Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  shopifyOrderId String?
  customerName   String?
  phoneNumber    String?
  ipAddress      String?
  postalCode     String?
  email          String?
  blockSource    BlockSource
  ruleId         Int?
  ruleType       String
  blockedAt      DateTime    @default(now())

  @@index([shopId, blockedAt])
  @@index([phoneNumber])
  @@index([ipAddress])
}

enum BlockSource {
  LEGACY_PHONE
  LEGACY_POSTAL_CODE
  BLOCKING_RULE
  RATE_LIMIT
}

model AdminCredential {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
