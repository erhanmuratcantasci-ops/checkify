# Backend API URL the dashboard talks to.
NEXT_PUBLIC_API_URL=https://api.chekkify.com

# Public Shopify API key (Client ID) for the embedded app. Surfaced to the
# browser so App Bridge can initialize via <meta name="shopify-api-key">.
# This value is public by design (it's the same key shown in OAuth URLs);
# the secret stays on the backend.
NEXT_PUBLIC_SHOPIFY_API_KEY=

# Canonical site URL for metadata (sitemap, robots, OG image).
NEXT_PUBLIC_SITE_URL=https://chekkify.com
